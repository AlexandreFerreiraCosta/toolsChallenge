<?xml version="1.0" encoding="UTF-8"?>
<profiles version="13">
    <profile kind="CodeFormatterProfile" name="CleanCodeEnterprise" version="13">

        <!-- ===================== -->
        <!-- TAMANHO DA LINHA -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.lineSplit" value="140"/>

        <!-- ===================== -->
        <!-- INDENTAÇÃO -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.tabulation.char" value="space"/>
        <setting id="org.eclipse.jdt.core.formatter.tabulation.size" value="4"/>
        <setting id="org.eclipse.jdt.core.formatter.indentation.size" value="4"/>

        <!-- ===================== -->
        <!-- BRACES -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.brace_position_for_type_declaration" value="end_of_line"/>
        <setting id="org.eclipse.jdt.core.formatter.brace_position_for_method_declaration" value="end_of_line"/>
        <setting id="org.eclipse.jdt.core.formatter.brace_position_for_block" value="end_of_line"/>
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_enum_constants" value="16"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_space_after_comma_in_enum_declarations" value="true"/>

        <!-- ===================== -->
        <!-- ESPAÇAMENTO -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.insert_space_after_comma_in_method_invocation_arguments" value="true"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_space_after_comma_in_method_declaration_parameters" value="true"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_space_after_comma_in_array_initializer" value="true"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_space_before_method_invocation_parentheses" value="false"/>

        <!-- ===================== -->
        <!-- WRAP - MÉTODOS -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_parameters_in_method_declaration" value="16"/>
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_arguments_in_method_invocation" value="16"/>
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_parameters_in_constructor_declaration" value="16"/>

        <!-- ===================== -->
        <!-- WRAP - CHAIN METHODS -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_selector_in_method_invocation" value="16"/>

        <!-- ===================== -->
        <!-- ANOTAÇÕES (SPRING) -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_annotations_on_method" value="16"/>
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_annotations_on_parameter" value="16"/>
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_annotations_on_type" value="16"/>

        <!-- ===================== -->
        <!-- CONTROLE DE QUEBRA -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.wrap_before_binary_operator" value="true"/>
        <setting id="org.eclipse.jdt.core.formatter.join_wrapped_lines" value="false"/>

        <!-- ===================== -->
        <!-- IF / ELSE / LOOPS -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.insert_new_line_before_else_in_if_statement" value="false"/>
        <setting id="org.eclipse.jdt.core.formatter.keep_else_statement_on_same_line" value="true"/>

        <!-- ===================== -->
        <!-- ARRAYS E LAMBDAS -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_expressions_in_array_initializer" value="16"/>
        <setting id="org.eclipse.jdt.core.formatter.alignment_for_lambda_body" value="16"/>

        <!-- ===================== -->
        <!-- IMPORTS (organização visual) -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.blank_lines_between_import_groups" value="1"/>

        <!-- ===================== -->
        <!-- LINHAS EM BRANCO -->
        <!-- ===================== -->
        <setting id="org.eclipse.jdt.core.formatter.blank_lines_before_method" value="1"/>
        <setting id="org.eclipse.jdt.core.formatter.blank_lines_after_method" value="1"/>

    </profile>
</profiles>